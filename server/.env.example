# ============================================
# QA Flow - Configuración
# ============================================

# ------------------------------------
# SERVIDOR
# ------------------------------------
PORT=3001
NODE_ENV=development

# ------------------------------------
# AUTENTICACIÓN (IMPORTANTE PARA PRODUCCIÓN)
# ------------------------------------
# Genera un secret seguro con: openssl rand -base64 32
JWT_SECRET="tu-secret-seguro-de-al-menos-32-caracteres"

# ------------------------------------
# DOCKER
# ------------------------------------
# Para usar con docker-compose, crea un archivo .env en la raíz:
# 
# PORT=3001
# NODE_ENV=production
# JWT_SECRET=tu-secret-muy-seguro
# DATABASE_URL=file:/app/data/qa-flow.db
#
# Para PostgreSQL (docker-compose.prod.yml):
# POSTGRES_PASSWORD=tu-password-seguro
# JWT_SECRET=tu-secret-muy-seguro

# ------------------------------------
# DESARROLLO LOCAL (SQLite - Por defecto)
# ------------------------------------
# SQLite es ideal para desarrollo local, no requiere configuración adicional
DATABASE_URL="file:./dev.db"

# ------------------------------------
# PRODUCCIÓN - PostgreSQL
# ------------------------------------
# Para conectar a PostgreSQL (Neon, Supabase, Railway, AWS RDS, Azure, etc.)
# Cambia el provider en prisma/schema.prisma de "sqlite" a "postgresql"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Ejemplos:
# Neon:      postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/qa_flow?sslmode=require
# Supabase:  postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# Railway:   postgresql://postgres:pass@containers-xxx.railway.app:5432/railway
# AWS RDS:   postgresql://admin:pass@qa-flow.xxx.us-east-1.rds.amazonaws.com:5432/qaflow
# Azure:     postgresql://admin@qa-flow:pass@qa-flow.postgres.database.azure.com:5432/qaflow?sslmode=require

# ------------------------------------
# PRODUCCIÓN - MySQL
# ------------------------------------
# Para conectar a MySQL (PlanetScale, AWS RDS, Azure, etc.)
# Cambia el provider en prisma/schema.prisma de "sqlite" a "mysql"
# DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Ejemplos:
# PlanetScale: mysql://user:pass@aws.connect.psdb.cloud/qa_flow?sslaccept=strict
# AWS RDS:     mysql://admin:pass@qa-flow.xxx.us-east-1.rds.amazonaws.com:3306/qaflow

# ------------------------------------
# PRODUCCIÓN - SQL Server
# ------------------------------------
# Para conectar a SQL Server (Azure SQL, AWS RDS, etc.)
# Cambia el provider en prisma/schema.prisma de "sqlite" a "sqlserver"
# DATABASE_URL="sqlserver://HOST:PORT;database=DATABASE;user=USER;password=PASSWORD;encrypt=true"
